# Required to download the gated Meta Llama model from Hugging Face.
# First request access at:
# https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=hf_replace_me

# Optional: use a local model path instead of downloading from Hugging Face.
MODEL_PATH=meta-llama/Llama-3.1-8B-Instruct

# Optional mirrors/caches.
HF_HOME=./models/huggingface-cache
